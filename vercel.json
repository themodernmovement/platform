{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/", "has": [{ "type": "host", "value": "www.icansayyes.org" }], "dest": "/icansayyes.html" },
    { "src": "/", "has": [{ "type": "host", "value": "icansayyes.org" }], "dest": "/icansayyes.html" },
    { "src": "/", "has": [{ "type": "host", "value": "www.youcansayno.org" }], "dest": "/youcansayno.html" },
    { "src": "/", "has": [{ "type": "host", "value": "youcansayno.org" }], "dest": "/youcansayno.html" },
    { "src": "/", "dest": "/platform.html" },
    { "src": "/say-no", "dest": "/youcansayno.html" },
    { "src": "/say-yes", "dest": "/icansayyes.html" },
    { "src": "/mission", "dest": "/mission.html" },
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/press", "dest": "/press.html" },
    { "handle": "filesystem" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/platform.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
